# ─── DATABASE ────────────────────────────────────────────
# Get free PostgreSQL from: https://neon.tech or https://supabase.com
DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/echocheck?sslmode=require"

# ─── NEXTAUTH ─────────────────────────────────────────────
# Generate secret: openssl rand -base64 32
NEXTAUTH_SECRET="your-super-secret-key-here"
NEXTAUTH_URL="http://localhost:3000"

# ─── GOOGLE OAUTH ─────────────────────────────────────────
# Get from: https://console.cloud.google.com → APIs & Services → Credentials
GOOGLE_CLIENT_ID="your-google-client-id.apps.googleusercontent.com"
GOOGLE_CLIENT_SECRET="your-google-client-secret"

# ─── STRIPE PAYMENTS ──────────────────────────────────────
# Get from: https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY="sk_test_your_stripe_secret_key"
STRIPE_WEBHOOK_SECRET="whsec_your_webhook_secret"
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY="pk_test_your_publishable_key"

# Pro Plan Price IDs (create in Stripe Dashboard → Products)
STRIPE_PRO_MONTHLY_PRICE_ID="price_your_pro_monthly_id"
STRIPE_PRO_YEARLY_PRICE_ID="price_your_pro_yearly_id"
STRIPE_CREATOR_MONTHLY_PRICE_ID="price_your_creator_monthly_id"

# ─── GOOGLE ADSENSE ───────────────────────────────────────
# Get from: https://adsense.google.com
NEXT_PUBLIC_ADSENSE_CLIENT_ID="ca-pub-your-adsense-id"
NEXT_PUBLIC_ADSENSE_SLOT_FEED="your-feed-ad-slot-id"
NEXT_PUBLIC_ADSENSE_SLOT_SIDEBAR="your-sidebar-ad-slot-id"

# ─── APP CONFIG ───────────────────────────────────────────
NEXT_PUBLIC_APP_URL="http://localhost:3000"
NEXT_PUBLIC_APP_NAME="EchoCheck"
